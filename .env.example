# ================================================
# ProjectTraveler - 환경변수 템플릿
# ================================================
# 사용법:
#   cp .env.example .env
#   .env 파일에서 값 수정 후 사용
#
# 주의: .env 파일은 절대 git에 커밋하지 말 것!
#       (이미 .gitignore에 포함되어 있음)
# ================================================

# ── MariaDB ──────────────────────────────────────
DB_ROOT_PASSWORD=your_root_password_here
DB_USER=lms_dev
DB_PASSWORD=your_db_password_here

# ── 로컬 개발용 기본값 (docker-compose.dev.yml) ──
# DB_ROOT_PASSWORD=root1234
# DB_USER=lms_dev
# DB_PASSWORD=dev1234

# ── 도메인 설정 (EC2 배포 시) ────────────────────
DOMAIN=yourdomain.com

# ── Spring 프로파일 ───────────────────────────────
# 로컬 개발: local
# EC2 운영:  prod
SPRING_PROFILES_ACTIVE=local